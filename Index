<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NutriPlanner - Your Nutrition Guide</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #6B8E6F;
            --primary-light: #8BA88D;
            --primary-dark: #4A6B4F;
            --background: #F5F1E8;
            --foreground: #2C3E35;
            --accent: #E8A89C;
            --accent-light: #F0BFB6;
            --secondary: #7BA3A0;
            --secondary-light: #A8C4C1;
            --card-bg: #FFFFFF;
            --border: #E0D9CE;
            --text-muted: #8B8B7E;
        }

        html, body {
            height: 100%;
            font-family: 'Inter', sans-serif;
            background-color: var(--background);
            color: var(--foreground);
            line-height: 1.6;
        }

        body {
            display: flex;
            flex-direction: column;
        }

        /* Navigation */
        nav {
            background-color: var(--card-bg);
            padding: 1rem 2rem;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
            text-decoration: none;
            font-family: 'Poppins', sans-serif;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links button {
            background: none;
            border: none;
            cursor: pointer;
            font-size: 1rem;
            color: var(--foreground);
            font-weight: 500;
            transition: color 0.3s ease;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
        }

        .nav-links button:hover {
            color: var(--primary);
        }

        .nav-links button.active {
            color: var(--primary);
            background-color: rgba(107, 142, 111, 0.1);
        }

        /* Main Content */
        main {
            flex: 1;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* Page Sections */
        .page {
            display: none;
        }

        .page.active {
            display: block;
        }

        /* Home Page */
        .hero {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            padding: 4rem 0;
            position: relative;
        }

        .hero-content h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 3.5rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 1.5rem;
            line-height: 1.2;
        }

        .hero-content p {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 2rem;
            line-height: 1.8;
        }

        .hero-buttons {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
        }

        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 0.65rem;
            font-weight: 600;
            font-size: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            font-family: 'Inter', sans-serif;
        }

        .btn-primary {
            background-color: var(--primary);
            color: white;
            box-shadow: 0 2px 8px rgba(107, 142, 111, 0.2);
        }

        .btn-primary:hover {
            background-color: var(--primary-dark);
            box-shadow: 0 4px 12px rgba(107, 142, 111, 0.3);
            transform: translateY(-2px);
        }

        .btn-secondary {
            background-color: var(--accent-light);
            color: var(--foreground);
            border: 1px solid var(--accent);
        }

        .btn-secondary:hover {
            background-color: var(--accent);
            transform: translateY(-2px);
        }

        .hero-image {
            position: relative;
            height: 400px;
            background: linear-gradient(135deg, rgba(107, 142, 111, 0.1) 0%, rgba(123, 163, 160, 0.1) 100%);
            border-radius: 1rem;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
        }

        /* Features Section */
        .features {
            padding: 4rem 0;
            background-color: var(--background);
        }

        .features-header {
            text-align: center;
            margin-bottom: 3rem;
        }

        .features-header h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .features-header p {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }

        .feature-card {
            background-color: var(--card-bg);
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid var(--border);
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .feature-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        }

        .feature-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .feature-card h3 {
            font-family: 'Poppins', sans-serif;
            font-size: 1.3rem;
            color: var(--foreground);
            margin-bottom: 0.5rem;
        }

        .feature-card p {
            color: var(--text-muted);
            line-height: 1.6;
        }

        /* CTA Section */
        .cta-section {
            background: linear-gradient(135deg, rgba(107, 142, 111, 0.05) 0%, rgba(123, 163, 160, 0.05) 100%);
            padding: 4rem 2rem;
            text-align: center;
            border-radius: 1rem;
            margin: 4rem 0;
        }

        .cta-section h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 2rem;
            color: var(--foreground);
            margin-bottom: 1rem;
        }

        .cta-section p {
            color: var(--text-muted);
            margin-bottom: 2rem;
            font-size: 1.1rem;
        }

        /* Calculator Page */
        .calculator-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            padding: 3rem 0;
        }

        .form-section {
            background-color: var(--card-bg);
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid var(--border);
        }

        .form-section h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            color: var(--foreground);
            margin-bottom: 1.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-group label {
            display: block;
            font-weight: 600;
            color: var(--foreground);
            margin-bottom: 0.5rem;
            font-size: 0.95rem;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--border);
            border-radius: 0.5rem;
            font-size: 1rem;
            font-family: 'Inter', sans-serif;
            background-color: var(--background);
            color: var(--foreground);
            transition: border-color 0.3s ease;
        }

        .form-group input:focus,
        .form-group select:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(107, 142, 111, 0.1);
        }

        .results-section {
            background-color: var(--card-bg);
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid var(--border);
            display: none;
        }

        .results-section.active {
            display: block;
        }

        .results-section h2 {
            font-family: 'Poppins', sans-serif;
            font-size: 1.5rem;
            color: var(--foreground);
            margin-bottom: 1.5rem;
        }

        .result-item {
            margin-bottom: 1.5rem;
            padding-bottom: 1.5rem;
            border-bottom: 1px solid var(--border);
        }

        .result-item:last-child {
            border-bottom: none;
        }

        .result-label {
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 0.3rem;
        }

        .result-value {
            font-family: 'Poppins', sans-serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
        }

        .macros-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1rem;
            margin-top: 1rem;
        }

        .macro-item {
            background-color: var(--background);
            padding: 1rem;
            border-radius: 0.5rem;
            text-align: center;
        }

        .macro-label {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-bottom: 0.3rem;
        }

        .macro-value {
            font-family: 'Poppins', sans-serif;
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--primary);
        }

        .macro-bar {
            height: 4px;
            background-color: var(--border);
            border-radius: 2px;
            margin-top: 0.5rem;
            overflow: hidden;
        }

        .macro-bar-fill {
            height: 100%;
            background-color: var(--primary);
            border-radius: 2px;
            transition: width 0.5s ease;
        }

        /* Meals Page */
        .meals-header {
            padding: 2rem 0;
            text-align: center;
        }

        .meals-header h1 {
            font-family: 'Poppins', sans-serif;
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .meals-header p {
            color: var(--text-muted);
            font-size: 1.1rem;
        }

        .filter-buttons {
            display: flex;
            gap: 1rem;
            margin: 2rem 0;
            flex-wrap: wrap;
            justify-content: center;
        }

        .filter-btn {
            padding: 0.6rem 1.2rem;
            border-radius: 0.5rem;
            border: 1px solid var(--border);
            background-color: transparent;
            color: var(--foreground);
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
            font-family: 'Inter', sans-serif;
        }

        .filter-btn:hover {
            border-color: var(--primary);
            color: var(--primary);
        }

        .filter-btn.active {
            background-color: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .meals-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            padding: 2rem 0;
        }

        .meal-card {
            background-color: var(--card-bg);
            border-radius: 1rem;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: all 0.3s ease;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .meal-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        }

        .meal-image {
            width: 100%;
            height: 200px;
            background: linear-gradient(135deg, rgba(107, 142, 111, 0.1) 0%, rgba(123, 163, 160, 0.1) 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 3rem;
            position: relative;
        }

        .meal-type-badge {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background-color: var(--primary);
            color: white;
            padding: 0.3rem 0.8rem;
            border-radius: 0.3rem;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: capitalize;
        }

        .meal-content {
            padding: 1.5rem;
        }

        .meal-content h3 {
            font-family: 'Poppins', sans-serif;
            font-size: 1.1rem;
            color: var(--foreground);
            margin-bottom: 0.5rem;
        }

        .meal-calories {
            display: flex;
            align-items: center;
            gap: 0.3rem;
            color: var(--primary);
            font-weight: 600;
            margin-bottom: 1rem;
        }

        .nutrition-info {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.5rem;
        }

        .nutrition-item {
            text-align: center;
            padding: 0.5rem;
            background-color: var(--background);
            border-radius: 0.3rem;
        }

        .nutrition-label {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.2rem;
            color: var(--text-muted);
            font-size: 0.75rem;
            margin-bottom: 0.2rem;
        }

        .nutrition-value {
            font-family: 'Poppins', sans-serif;
            font-weight: 700;
            color: var(--foreground);
            font-size: 0.95rem;
        }

        .nutrition-bar {
            height: 3px;
            background-color: var(--border);
            border-radius: 2px;
            margin-top: 0.3rem;
            overflow: hidden;
        }

        .nutrition-bar-fill {
            height: 100%;
            background-color: var(--primary);
            border-radius: 2px;
        }

        /* Footer */
        footer {
            background-color: var(--card-bg);
            padding: 2rem;
            text-align: center;
            border-top: 1px solid var(--border);
            margin-top: 4rem;
        }

        footer p {
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        footer .subtitle {
            color: var(--text-muted);
            font-size: 0.85rem;
            margin-top: 0.5rem;
        }

        /* Error Message */
        .error-message {
            background-color: #FFE5E5;
            color: #C41E3A;
            padding: 1rem;
            border-radius: 0.5rem;
            margin-bottom: 1rem;
            display: none;
        }

        .error-message.show {
            display: block;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero {
                grid-template-columns: 1fr;
                padding: 2rem 0;
            }

            .hero-content h1 {
                font-size: 2.5rem;
            }

            .features-grid {
                grid-template-columns: 1fr;
            }

            .calculator-container {
                grid-template-columns: 1fr;
            }

            .nav-links {
                gap: 1rem;
            }

            .meals-grid {
                grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            }

            .hero-buttons {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="nav-container">
            <a href="#" class="logo">🌿 NutriPlanner</a>
            <ul class="nav-links">
                <li><button class="nav-btn active" data-page="home">Home</button></li>
                <li><button class="nav-btn" data-page="calculator">Calculator</button></li>
                <li><button class="nav-btn" data-page="meals">Meals</button></li>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container">
        <!-- Home Page -->
        <div id="home" class="page active">
            <section class="hero">
                <div class="hero-content">
                    <h1>Your Path to Optimal Nutrition</h1>
                    <p>Calculate your daily nutrition needs, discover balanced meal ideas, and take control of your health journey with science-backed guidance.</p>
                    <div class="hero-buttons">
                        <button class="btn btn-primary" onclick="navigateTo('calculator')">Get Started →</button>
                        <button class="btn btn-secondary" onclick="navigateTo('meals')">Browse Meals 🍽️</button>
                    </div>
                </div>
                <div class="hero-image">🥗</div>
            </section>

            <section class="features">
                <div class="features-header">
                    <h2>Complete Nutrition Planning</h2>
                    <p>Everything you need to understand and optimize your nutrition</p>
                </div>
                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon">📊</div>
                        <h3>Personalized Calculator</h3>
                        <p>Calculate your daily calorie and macro requirements based on your unique profile, activity level, and fitness goals.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">🍽️</div>
                        <h3>Meal Ideas Database</h3>
                        <p>Explore a curated collection of healthy meals with complete nutritional information for breakfast, lunch, dinner, and snacks.</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon">🌿</div>
                        <h3>Wellness Guidance</h3>
                        <p>Get science-backed recommendations to help you achieve your health and fitness objectives with confidence.</p>
                    </div>
                </div>
            </section>

            <section class="cta-section">
                <h2>Ready to Transform Your Nutrition?</h2>
                <p>Start your journey today and discover how proper nutrition can enhance your health, energy, and overall well-being.</p>
                <button class="btn btn-primary" onclick="navigateTo('calculator')">Calculate Your Needs →</button>
            </section>
        </div>

        <!-- Calculator Page -->
        <div id="calculator" class="page">
            <div class="calculator-container">
                <div class="form-section">
                    <h2>Your Profile</h2>
                    <div class="error-message" id="error"></div>
                    
                    <div class="form-group">
                        <label>Age (years)</label>
                        <input type="number" id="age" min="10" max="120" value="25" placeholder="25">
                    </div>

                    <div class="form-group">
                        <label>Gender</label>
                        <select id="gender">
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Weight (kg)</label>
                        <input type="number" id="weight" min="30" max="300" value="70" placeholder="70">
                    </div>

                    <div class="form-group">
                        <label>Height (cm)</label>
                        <input type="number" id="height" min="100" max="250" value="175" placeholder="175">
                    </div>

                    <div class="form-group">
                        <label>Activity Level</label>
                        <select id="activityLevel">
                            <option value="sedentary">Sedentary (little or no exercise)</option>
                            <option value="light">Light (1-3 days/week)</option>
                            <option value="moderate" selected>Moderate (3-5 days/week)</option>
                            <option value="active">Active (6-7 days/week)</option>
                            <option value="veryActive">Very Active (intense exercise)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label>Goal</label>
                        <select id="goal">
                            <option value="weightLoss">Weight Loss</option>
                            <option value="maintenance" selected>Maintenance</option>
                            <option value="muscleGain">Muscle Gain</option>
                        </select>
                    </div>

                    <button class="btn btn-primary" onclick="calculateNutrition()" style="width: 100%; margin-top: 1rem;">Calculate My Nutrition</button>
                </div>

                <div class="results-section" id="results">
                    <h2>Daily Requirements</h2>
                    
                    <div class="result-item">
                        <div class="result-label">Calories</div>
                        <div class="result-value" id="caloriesResult">0</div>
                    </div>

                    <div class="result-item">
                        <div class="result-label">BMR (Basal Metabolic Rate)</div>
                        <div class="result-value" id="bmrResult">0</div>
                    </div>

                    <div class="result-item">
                        <div class="result-label">TDEE (Total Daily Energy Expenditure)</div>
                        <div class="result-value" id="tdeeResult">0</div>
                    </div>

                    <div class="result-item">
                        <div class="result-label">Macronutrients</div>
                        <div class="macros-grid">
                            <div class="macro-item">
                                <div class="macro-label">Protein</div>
                                <div class="macro-value" id="proteinResult">0g</div>
                                <div class="macro-bar">
                                    <div class="macro-bar-fill" style="width: 30%"></div>
                                </div>
                            </div>
                            <div class="macro-item">
                                <div class="macro-label">Carbs</div>
                                <div class="macro-value" id="carbsResult">0g</div>
                                <div class="macro-bar">
                                    <div class="macro-bar-fill" style="width: 40%"></div>
                                </div>
                            </div>
                            <div class="macro-item">
                                <div class="macro-label">Fats</div>
                                <div class="macro-value" id="fatsResult">0g</div>
                                <div class="macro-bar">
                                    <div class="macro-bar-fill" style="width: 30%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button class="btn btn-secondary" onclick="navigateTo('meals')" style="width: 100%; margin-top: 1rem;">Explore Meal Ideas</button>
                </div>
            </div>
        </div>

        <!-- Meals Page -->
        <div id="meals" class="page">
            <section class="meals-header">
                <h1>Meal Ideas</h1>
                <p>Discover nutritious and delicious meal options for every occasion</p>
            </section>

            <div class="filter-buttons">
                <button class="filter-btn active" onclick="filterMeals('all')">All Meals</button>
                <button class="filter-btn" onclick="filterMeals('breakfast')">Breakfast</button>
                <button class="filter-btn" onclick="filterMeals('lunch')">Lunch</button>
                <button class="filter-btn" onclick="filterMeals('dinner')">Dinner</button>
                <button class="filter-btn" onclick="filterMeals('snack')">Snack</button>
            </div>

            <div class="meals-grid" id="mealsGrid"></div>

            <section class="cta-section" style="margin-top: 4rem;">
                <h2>Need Help Planning Your Meals?</h2>
                <p>Use our nutrition calculator to determine your daily calorie and macro requirements, then select meals that fit your goals.</p>
                <button class="btn btn-primary" onclick="navigateTo('calculator')">Go to Calculator</button>
            </section>
        </div>
    </main>

    <!-- Footer -->
    <footer>
        <p>© 2026 NutriPlanner - Your Personal Nutrition Guide</p>
        <p class="subtitle">Designed with care for your health and wellness journey</p>
    </footer>

    <script>
        // Meals Database
        const meals = [
            { id: 1, name: "Oatmeal with Berries", type: "breakfast", calories: 350, protein: 12, carbs: 55, fats: 8, emoji: "🥣" },
            { id: 2, name: "Eggs and Toast", type: "breakfast", calories: 380, protein: 18, carbs: 35, fats: 15, emoji: "🍳" },
            { id: 3, name: "Protein Smoothie", type: "breakfast", calories: 320, protein: 25, carbs: 42, fats: 6, emoji: "🥤" },
            { id: 4, name: "Yogurt Parfait", type: "breakfast", calories: 280, protein: 15, carbs: 45, fats: 5, emoji: "🍨" },
            { id: 5, name: "Grilled Chicken Salad", type: "lunch", calories: 420, protein: 35, carbs: 30, fats: 12, emoji: "🥗" },
            { id: 6, name: "Salmon with Rice", type: "lunch", calories: 520, protein: 40, carbs: 50, fats: 15, emoji: "🍣" },
            { id: 7, name: "Vegetable Wrap", type: "lunch", calories: 380, protein: 15, carbs: 55, fats: 10, emoji: "🌯" },
